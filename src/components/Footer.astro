---
import logo from "../assets/logos/brandemic-logo.svg";
---

<footer class="footer">
  <div class="container">

    <!-- Top Section -->
    <div class="footer-top">

      <div class="footer-left">

        <img src={logo.src} alt="Brandemic" class="footer-logo" />

        <nav class="footer-nav">
          <a href="#">Portfolio</a>
          <a href="#">Services</a>
          <a href="#">About Us</a>
          <a href="#">Contact</a>
        </nav>

        <div class="footer-policy">
          <a href="#">Privacy Policy</a>
          <a href="#">Terms of Use</a>
        </div>

      </div>

      <div class="footer-right">

        <p class="newsletter-title">
          STAY UP TO DATE
        </p>

        <form class="newsletter-form">

          <input
            type="email"
            placeholder="Subscribe With Email"
          />

          <button type="submit">
            →
          </button>

        </form>

      </div>

    </div>

    <!-- Middle -->

    <div class="footer-middle">

      <div>
        <p class="footer-email">
          info@brandemic.in
        </p>
      </div>

      <div>
        <p class="footer-connect">
          CONNECT TODAY
        </p>
      </div>

    </div>

    <!-- Giant Text -->

    <h2 class="footer-title">
      THINK LIMITLESS
    </h2>

    <div class="footer-divider"></div>

    <!-- Bottom -->

    <div class="footer-bottom">

    <p class="copyright">
        © 2026 Brandemic. All rights reserved.
    </p>

    <div class="made-by">
        <span>Made with passion by</span>
        <img
            src="src/assets/logos/footer-small-logo.svg"
            alt="Brandemic"
        />
    </div>

    <div class="footer-socials">
        <a href="https://x.com/brandemicglobal">
            <img src="src/assets/icons/twitter.svg" alt="Twitter">
        </a>
        <a href="https://www.facebook.com/brandemic.design#">
            <img src="src/assets/icons/facebook.svg" alt="Facebook">
        </a>
        <a href="https://www.youtube.com/@Brandemic_Design">
            <img src="src/assets/icons/youtube.svg" alt="Youtube">
        </a>
        <a href="https://www.instagram.com/brandemic_design/">
            <img src="src/assets/icons/instagram.svg" alt="Instagram">
        </a>
        <a href="https://www.behance.net/brandemic">
            <img src="src/assets/icons/behance.svg" alt="Behance">
        </a>
        <a href="https://www.linkedin.com/company/brandemic-design/">
            <img src="src/assets/icons/linkedin.svg" alt="LinkedIn">
        </a>
    </div>
</div>

  </div>
</footer>